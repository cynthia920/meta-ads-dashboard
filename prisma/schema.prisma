// Phase 1 schema for the AI community moderation dashboard.
// Tables are wired for the full v1 feature set; columns are added incrementally
// in later phases (encryption, RBAC, etc.).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Dashboard users (NextAuth) ----------

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String?
  image         String?
  emailVerified DateTime?
  createdAt     DateTime      @default(now())

  sessions      Session[]
  authAccounts  AuthAccount[]
  metaAccounts  MetaAccount[]
  savedViews    SavedView[]
}

model AuthAccount {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Connected Meta entities (FB Pages + IG Business) ----------

enum Platform {
  FB_PAGE
  IG_BUSINESS
}

enum TokenStatus {
  ACTIVE
  EXPIRING_SOON
  EXPIRED
  REVOKED
}

model MetaAccount {
  id              String       @id @default(cuid())
  ownerId         String
  owner           User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  platform        Platform
  externalId      String // FB page id or IG user id
  name            String
  pictureUrl      String?

  // Long-lived Page / IG token. Encrypted at rest in Phase 3.
  accessToken     String       @db.Text
  tokenExpiresAt  DateTime?
  tokenStatus     TokenStatus  @default(ACTIVE)

  // For ad ingest — the ad account this page is associated with.
  adAccountId     String?

  connectedAt     DateTime     @default(now())
  lastSyncedAt    DateTime?

  settings        AccountSettings?
  posts           Post[]

  @@unique([platform, externalId])
  @@index([ownerId])
}

model AccountSettings {
  id                  String      @id @default(cuid())
  accountId           String      @unique
  account             MetaAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  // ["en", "es", "ko", "zh", "ja"] — comments outside this list go to PENDING_REVIEW.
  languageScope       String[]    @default(["en", "es", "ko", "zh", "ja"])

  // Serialized rule set, e.g.
  //   [{ "category": "SPAM", "minConfidence": 0.9, "action": "AUTO_HIDE" }, ...]
  autoHideRules       Json        @default("[]")

  // Cron poll interval in minutes.
  pollIntervalMinutes Int         @default(10)

  updatedAt           DateTime    @updatedAt
}

// ---------- Posts (organic + ad) ----------

enum PostSource {
  ORGANIC
  AD
}

model Post {
  id            String      @id @default(cuid())
  accountId     String
  account       MetaAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  externalId    String // FB post id or IG media id
  source        PostSource
  caption       String?     @db.Text
  thumbnailUrl  String?
  permalink     String?

  // Ad-only metadata
  adId          String?
  adsetId       String?
  campaignId    String?
  adName        String?

  publishedAt   DateTime?
  lastPolledAt  DateTime?

  comments      Comment[]

  @@unique([accountId, externalId])
  @@index([accountId, source])
  @@index([lastPolledAt])
}

// ---------- Comments ----------

enum Classifier {
  SPAM
  TOXIC
  NEGATIVE_GENUINE
  NEUTRAL
  POSITIVE
}

enum CommentStatus {
  VISIBLE
  HIDDEN
  PENDING_REVIEW
}

model Comment {
  id                   String        @id @default(cuid())
  postId               String
  post                 Post          @relation(fields: [postId], references: [id], onDelete: Cascade)

  externalId           String        @unique // Graph API comment id
  parentExternalId     String? // present if this is a reply
  authorName           String?
  authorExternalId     String?
  message              String        @db.Text
  externalCreatedAt    DateTime

  // Language detection
  detectedLanguage     String? // ISO 639-1 code: "en", "es", "ko", "zh", "ja", ...
  languageConfidence   Float?
  translationEn        String?       @db.Text

  // Classification
  classifier           Classifier?
  classifierConfidence Float?
  classifierReason     String?       @db.Text
  classifierEditedById String? // user id if a human overrode
  classifierEditedAt   DateTime?

  // Moderation state
  status               CommentStatus @default(VISIBLE)
  hiddenAt             DateTime?
  hiddenBy             String? // user id, or "auto"

  ingestedAt           DateTime      @default(now())
  classifiedAt         DateTime?

  auditEvents          AuditEvent[]

  @@index([postId])
  @@index([status])
  @@index([classifier])
  @@index([detectedLanguage])
  @@index([parentExternalId])
}

// ---------- Audit log ----------

enum AuditAction {
  INGESTED
  CLASSIFIED
  RECLASSIFIED
  LANGUAGE_EDITED
  HIDDEN
  UNHIDDEN
  MARKED_SAFE
  REPLIED
}

model AuditEvent {
  id        String      @id @default(cuid())
  commentId String
  comment   Comment     @relation(fields: [commentId], references: [id], onDelete: Cascade)

  action    AuditAction
  actor     String // user id, or "auto"
  metadata  Json?
  createdAt DateTime    @default(now())

  @@index([commentId])
  @@index([createdAt])
}

// ---------- Saved filter views ----------

model SavedView {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  filters   Json
  createdAt DateTime @default(now())

  @@index([userId])
}

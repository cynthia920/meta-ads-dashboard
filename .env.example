# Meta Marketing API
# Create a System User token in Business Manager with ads_read scope.
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_1234567890
META_API_VERSION=v21.0

# Amazon Attribution (Amazon Ads API)
# https://advertising.amazon.com/API/docs/en-us/reference/2/attribution
AMAZON_ACCESS_TOKEN=
AMAZON_CLIENT_ID=
AMAZON_PROFILE_ID=
AMAZON_API_HOST=https://advertising-api.amazon.com

# Default report window (days)
REPORT_LOOKBACK_DAYS=30
